# Frontend environment variables
# Copy this file to .env and fill in the real values.
# NEVER commit the .env file.

# Backend API Gateway URL (HTTP)
NUXT_PUBLIC_API_URL=https://your-api-id.execute-api.eu-west-1.amazonaws.com

# Backend API Gateway URL (WebSocket)
NUXT_PUBLIC_WS_URL=wss://your-ws-id.execute-api.eu-west-1.amazonaws.com/dev
